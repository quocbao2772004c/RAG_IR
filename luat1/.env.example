TEACHER_BASE_URL=http://192.168.50.218:8000/api/v1
LLM_BASE_URL=http://192.168.50.218:8000/api/v1/proxy
STUDENT_ID=B22XXXXXXX
STUDENT_SERVER_URL=http://<IP-LAN-cua-may>:5005
HOST=0.0.0.0
PORT=5005
LLM_MODEL=gpt-4o-mini
# Set this when the LLM server key is different from STUDENT_ID.
LLM_API_KEY=
LLM_TEMPERATURE=0.0
LLM_TIMEOUT=45
LLM_MAX_TOKENS=8
LLM_VERIFY=true
# Retrieval modes:
# - bm25: lexical/exact search, fastest upload and best score on the current benchmark.
# - hybrid: combines BM25 with local EMBEDDING_MODEL; requires downloaded model and vector DB.
# - sbert or vector: local EMBEDDING_MODEL only.
# - openai: OPENAI_EMBEDDING_MODEL through the configured OpenAI-compatible endpoint.
# Current benchmark: bm25=85.61%, hybrid=84.75%. Keep hybrid when semantic retrieval is required.
RETRIEVER_BACKEND=hybrid
RETRIEVE_WITH_OPTIONS=false
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
DEVICE=cpu
MODEL_LOCAL_ONLY=true
CHROMA_DB_DIR=chroma_db
CHROMA_COLLECTION=student_rag_luat1
CHROMA_BATCH_SIZE=256
EMBEDDING_BATCH_SIZE=64
CHUNK_SIZE=2200
CHUNK_OVERLAP=0
# Safe defaults for models with a 4096-token context window.
TOP_K=8
MAX_CONTEXT_CHARS=8000
VECTOR_CANDIDATES=80
BM25_WEIGHT=0.88
# Optional reranker. Leave empty for faster startup.
RERANKER_MODEL=
RERANK_CANDIDATES=20
RERANKER_BATCH_SIZE=4
RERANKER_MAX_LENGTH=512
# Single deduplicated question bank used by --map.
QUESTION_BANK_PATHS=../data/merged_questions.json
QUESTION_BANK_MIN_SIMILARITY=0.94
